{
  "name": "mcu-track",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev",
    "dev:backend": "cd backend && go run main.go",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "backend:download": "cd backend && go mod download",
    "backend:build": "cd backend && go build -o mcutrack-api.exe",
    "backend:run": "cd backend && ./mcutrack-api.exe"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "jose": "^6.1.3",
    "next": "^15.5.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.0.0",
    "typescript": "^5.0.0"
  }
}
